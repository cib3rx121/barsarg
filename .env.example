# Nao commitar credenciais reais.
#
# Neon (https://console.neon.tech): Dashboard do projeto → Connect → copia a connection string.
# - Inclui normalmente ?sslmode=require — mantem isso.
# - Para `npm run db:migrate:deploy`, a Neon recomenda a ligacao DIRECTA (nao pooled),
#   para migracoes funcionarem bem. No painel costuma haver "direct" vs "pooled".
# - A mesma URL pode servir na Vercel em MVP; se mais tarde usares pooler no runtime,
#   migracoes continuam a ser com direct (ou corre migracoes via GitHub Action com secret).
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require&schema=public

# Admin MVP
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troca_me

# PIN inicial da pagina publica /consulta
PUBLIC_CONSULT_PIN=1234

# Recomendado em produção: URL pública do site (https://...) — usada como fallback se o
# pedido não trouxer o domínio nos cabeçalhos (ex.: QR code da consulta no painel admin).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upload direto de comprovativos (Vercel Blob)
# Criar token em Vercel -> Storage -> Blob -> Read/Write Token
BLOB_READ_WRITE_TOKEN=

