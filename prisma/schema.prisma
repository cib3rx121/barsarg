// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id @default(uuid()) @db.Uuid
  name            String
  entryDate       DateTime      @db.Date
  /// Primeiro mês com cota; null = desde o mês civil da entrada.
  chargeStartDate DateTime?     @db.Date
  active          Boolean       @default(true)
  publicTokenHash String        @unique
  createdAt       DateTime      @default(now())
  ledgerEntries   LedgerEntry[]
  waivedMonths    WaivedMonth[]
}

/// Mês em que a pessoa não deve cota (ex.: ausência); remove a carga CHARGE_MONTH desse mês.
model WaivedMonth {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  monthKey  String
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
  @@index([userId])
}

/// Um único registo (id = "default"): valor mensal igual para todos os meses.
model QuotaSettings {
  id                String   @id
  amountCents       Int
  adminUsername     String?
  adminPasswordHash String?
  consultaPinHash   String?
  publicNotice      String?
  updatedAt         DateTime @updatedAt
}

/// Saldo do utilizador = soma(deltaCents). Positivo = deve ao bar; negativo = crédito.
model LedgerEntry {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  deltaCents Int
  kind       String
  monthKey   String?
  note       String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actor     String
  action    String
  entity    String
  entityId  String?
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model MonthClosure {
  id                String   @id @default(uuid()) @db.Uuid
  monthKey          String   @unique
  totalUsers        Int
  debtUsers         Int
  creditUsers       Int
  totalDebtCents    Int
  totalCreditCents  Int
  totalReceivedCents Int
  closedAt          DateTime @default(now())
}
